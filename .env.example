# Popbill(팝빌) 세금계산서 발행 설정
# 아래 3개 키(LINK_ID, SECRET_KEY, CORP_NUM)가 없으면 mock 모드로 동작합니다.

POPBILL_LINK_ID=          # 팝빌 연동회원 링크아이디
POPBILL_SECRET_KEY=       # 팝빌 비밀키(SecretKey)
POPBILL_CORP_NUM=         # 공급자(발행사업자) 사업자번호, 숫자만
POPBILL_CORP_NAME=        # 공급자 상호명
POPBILL_CEO_NAME=         # 공급자 대표자명
POPBILL_USER_ID=          # 팝빌 회원 아이디
POPBILL_IS_TEST=true      # true=테스트(샌드박스), false=운영

# AI 견적 초안
# 키가 없으면 AI 초안 버튼이 안내 메시지를 반환합니다.
# 무료 발급: https://aistudio.google.com/apikey (Gemini 키가 있으면 우선 사용)
GEMINI_API_KEY=
# ANTHROPIC_API_KEY는 유료 대안입니다. (Gemini 키가 없을 때 사용)
ANTHROPIC_API_KEY=
