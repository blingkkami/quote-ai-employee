# Supabase 로그인 및 사용자별 데이터 저장
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY= # 서버 전용. 브라우저에 노출하거나 VITE_ 접두사를 붙이지 않습니다.

# 팝빌 프로그램 공급사 설정 (Vercel에는 아래 한 개만 등록)
POPBILL_CONFIG={"linkId":"발급받은_LinkID","secretKey":"발급받은_SecretKey","corpNum":"조회비용을_부담할_사업자번호10자리","isTest":true}

# 사용자별 발신메일 연결
APP_URL=https://quote.blingkkami.com
EMAIL_TOKEN_ENCRYPTION_KEY= # openssl rand -base64 32 로 생성, 서버 전용

# Google Gmail / Google Workspace OAuth
GOOGLE_EMAIL_CLIENT_ID=
GOOGLE_EMAIL_CLIENT_SECRET=
GOOGLE_EMAIL_REDIRECT_URI=https://quote.blingkkami.com/api/email/google-callback

# Outlook / Microsoft 365 OAuth
MICROSOFT_EMAIL_CLIENT_ID=
MICROSOFT_EMAIL_CLIENT_SECRET=
MICROSOFT_EMAIL_REDIRECT_URI=https://quote.blingkkami.com/api/email/microsoft-callback

# PortOne V2 결제 (서버 전용, 브라우저에는 checkout API가 필요한 공개 식별자만 전달)
PORTONE_STORE_ID=
PORTONE_CHANNEL_KEY=
PORTONE_API_SECRET=
BILLING_TOKEN_ENCRYPTION_KEY= # openssl rand -base64 32 로 생성
